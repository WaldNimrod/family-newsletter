<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Family Newsletter - {{ neo.date }}</title>
{% if og_image_url %}
<meta property="og:image" content="{{ og_image_url }}">
<meta property="og:image:width" content="1080">
<meta property="og:image:height" content="1350">
<meta property="og:title" content="Family Newsletter — {{ neo.date_formatted or neo.date }}">
<meta property="og:type" content="website">
<meta name="twitter:card" content="summary_large_image">
{% endif %}
<link href="https://fonts.googleapis.com/css2?family=Bangers&family=Patrick+Hand&display=swap" rel="stylesheet">
<style>
  :root {
    --red: #c0392b;
    --blue: #2471a3;
    --green: #27ae60;
    --purple: #7d3c98;
    --yellow: #f39c12;
    --orange: #e67e22;
    --bg: #fdf6e3;
    --ink: #2c2c2c;
    --panel-bg: #fff;
    --nimrod: #2471a3;
    --michal: #27ae60;
    --shaked: #7d3c98;
    --maayan: #c0392b;
    --tzlil: #e67e22;
    --shadow-color: var(--ink);
    --dot-color: #e8dcc8;
    --nimrod-bg: #e6f0fa;
    --michal-bg: #e6f5ed;
    --shaked-bg: #ece6f5;
    --maayan-bg: #fce8ec;
    --tzlil-bg: #fef3e2;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1a1815;
      --ink: #eee8dc;
      --panel-bg: #241f19;
      --shadow-color: #000000;
      --dot-color: #2a251e;
      --nimrod-bg: #16324a;
      --michal-bg: #123a26;
      --shaked-bg: #2e2140;
      --maayan-bg: #45202a;
      --tzlil-bg: #4a3410;
    }
    .opener { background: linear-gradient(135deg, #2e2a12 0%, #26220d 100%); }
    .closer { background: linear-gradient(135deg, #0f2620, #0c2118); }
    .discovery-panel { background: #241b2e; }
    .puzzle-panel { background: #2e2a12; }
    .history-panel { background: #2e2413; }
    .survey-panel { background: linear-gradient(135deg, #12212e, #0d1b26); }
    .viewing-panel { background: #0f2530; }
    .family-table-panel { background: #2b2013; }
    .shelf-panel { background: #241f18; }
    .extended-family-panel { background: #2b1720; }
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Patrick Hand', 'Comic Sans MS', cursive, sans-serif;
    background: var(--bg);
    color: var(--ink);
    line-height: 1.6;
    direction: rtl;
    background-image: radial-gradient(circle, var(--dot-color) 1px, transparent 1px);
    background-size: 16px 16px;
  }
  .page { max-width: 640px; margin: 0 auto; padding: 8px; }

  /* ===== COVER / HEADER ===== */
  .cover {
    background: var(--panel-bg);
    border: 4px solid var(--ink);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 12px;
    box-shadow: 6px 6px 0 var(--shadow-color);
    position: relative;
  }
  .cover-top {
    background: linear-gradient(135deg, var(--red) 0%, #e74c3c 50%, var(--orange) 100%);
    padding: 24px 20px 16px;
    text-align: center;
    position: relative;
    background-image: repeating-linear-gradient(-45deg, transparent, transparent 10px, rgba(255,255,255,0.08) 10px, rgba(255,255,255,0.08) 20px);
  }
  .cover-top .masthead {
    font-family: 'Bangers', cursive;
    font-size: 36px;
    color: #fff;
    letter-spacing: 3px;
    text-shadow: 3px 3px 0 var(--ink), -1px -1px 0 var(--ink);
    line-height: 1.1;
  }
  .cover-top .subtitle { font-size: 15px; color: rgba(255,255,255,0.9); margin-top: 2px; }
  .cover-top .edition-badge {
    display: inline-block;
    background: var(--yellow);
    color: var(--ink);
    font-family: 'Bangers', cursive;
    font-size: 13px;
    padding: 2px 12px;
    border-radius: 20px;
    border: 2px solid var(--ink);
    margin-top: 8px;
    letter-spacing: 1px;
  }
  .cover-body { padding: 16px 20px; position: relative; }
  .mascot-bubble {
    background: #fff;
    border: 3px solid var(--ink);
    border-radius: 18px;
    padding: 14px 16px;
    position: relative;
    font-size: 16px;
    line-height: 1.55;
    margin-bottom: 8px;
  }
  .mascot-bubble::before { content: ''; position: absolute; bottom: -14px; right: 30px; width: 0; height: 0; border-left: 14px solid transparent; border-right: 0px solid transparent; border-top: 14px solid var(--ink); }
  .mascot-bubble::after { content: ''; position: absolute; bottom: -10px; right: 32px; width: 0; height: 0; border-left: 11px solid transparent; border-right: 0px solid transparent; border-top: 11px solid #fff; }
  .mascot-name { font-family: 'Bangers', cursive; font-size: 13px; color: var(--red); margin-top: 16px; padding-right: 4px; letter-spacing: 1px; }

  /* ===== OPENER (פתיח) ===== */
  .opener {
    background: linear-gradient(135deg, #fef9e7 0%, #fcf3cf 100%);
    border: 3px solid var(--yellow);
    border-radius: 14px;
    padding: 16px 20px;
    margin-bottom: 12px;
    box-shadow: 4px 4px 0 rgba(0,0,0,0.1);
    position: relative;
    overflow: hidden;
  }
  .opener::before {
    content: '☀️';
    position: absolute;
    top: -10px;
    left: -5px;
    font-size: 60px;
    opacity: 0.12;
  }
  .opener h3 { font-family: 'Bangers', cursive; font-size: 18px; color: var(--orange); margin-bottom: 6px; letter-spacing: 1px; }
  .opener p { font-size: 15px; color: #555; }
  .opener strong { font-weight: bold; color: var(--ink); }

  /* ===== WEEKLY WEATHER FORECAST ===== */
  .weather-section {
    background: var(--panel-bg);
    border: 3px solid var(--ink);
    border-radius: 14px;
    margin-bottom: 12px;
    box-shadow: 4px 4px 0 var(--shadow-color);
    overflow: hidden;
  }
  .weather-header {
    padding: 10px 16px;
    font-family: 'Bangers', cursive;
    font-size: 16px;
    color: var(--blue);
    letter-spacing: 1px;
    border-bottom: 2px solid #eee;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .weather-header .toggle-arrow { font-size: 12px; color: #bbb; transition: transform 0.2s; }
  .weather-section.expanded .toggle-arrow { transform: rotate(180deg); }
  .weather-overview {
    display: flex;
    gap: 6px;
    padding: 12px 16px;
    border-bottom: 2px dashed #eee;
  }
  .weather-mini {
    flex: 1;
    text-align: center;
    padding: 8px 4px;
    border-radius: 8px;
  }
  .weather-mini .w-city { font-family: 'Bangers', cursive; font-size: 12px; color: var(--blue); letter-spacing: 0.5px; }
  .weather-mini .w-temp { font-size: 22px; font-weight: bold; margin: 2px 0; }
  .weather-mini .w-icon { font-size: 20px; }
  .wind-highlight { background: #fff3cd; border: 2px solid var(--orange); border-radius: 8px; animation: pulse 2s infinite; }
  .wind-highlight .w-city { color: var(--red); }
  @keyframes pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.02); } }

  /* Weather detail (expandable per location) */
  .weather-details { display: none; padding: 0; }
  .weather-section.expanded .weather-details { display: block; }
  .weather-loc {
    padding: 12px 16px;
    border-bottom: 1px solid #f0f0f0;
    cursor: pointer;
  }
  .weather-loc:last-child { border-bottom: none; }
  .weather-loc-header {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: bold;
    font-size: 15px;
    margin-bottom: 6px;
  }
  .weather-loc-header .loc-icon { font-size: 20px; }
  .weather-graph {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 50px;
    padding: 4px 0;
  }
  .weather-graph .bar {
    flex: 1;
    border-radius: 4px 4px 0 0;
    min-width: 12px;
    position: relative;
    transition: height 0.3s;
  }
  .weather-graph .bar .bar-label {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 10px;
    color: #888;
    font-family: sans-serif;
    white-space: nowrap;
  }
  .weather-graph .bar .day-label {
    position: absolute;
    bottom: -14px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 9px;
    color: #aaa;
    font-family: sans-serif;
  }
  .weather-loc-desc { font-size: 13px; color: #666; margin-top: 8px; line-height: 1.6; }

  /* ===== SECTION SEPARATOR ===== */
  .section-sep {
    text-align: center;
    padding: 10px 0;
    font-family: 'Bangers', cursive;
    font-size: 14px;
    color: #ccc;
    letter-spacing: 3px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .section-sep::before, .section-sep::after { content: ''; flex: 1; height: 2px; background: repeating-linear-gradient(90deg, #ddd, #ddd 4px, transparent 4px, transparent 8px); }

  /* ===== CONTENT GRID ===== */
  .grid { display: flex; flex-direction: column; gap: 10px; }

  /* ===== LEVEL 1: HERO PANEL ===== */
  .panel-level1 {
    background: var(--panel-bg);
    border: 4px solid var(--ink);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 6px 6px 0 var(--shadow-color);
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    position: relative;
  }
  .panel-level1:hover { transform: translate(-2px, -2px); box-shadow: 8px 8px 0 var(--shadow-color); }
  .panel-level1 .hero-visual {
    position: relative;
    min-height: 220px;
    background: linear-gradient(135deg, #e8f4fd, #d6eaf8);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .panel-level1 .hero-visual img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    border-bottom: 3px solid var(--ink);
  }
  .character-placeholder {
    position: absolute;
    bottom: 10px;
    left: 10px;
    width: 90px;
    height: 120px;
    background: rgba(255,255,255,0.9);
    border: 2px dashed var(--ink);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: #888;
    font-family: sans-serif;
  }
  .character-placeholder .char-emoji { font-size: 36px; margin-bottom: 4px; }
  .panel-level1 .hero-body { padding: 16px 20px; }
  .panel-level1 .hero-body .category {
    font-family: 'Bangers', cursive;
    font-size: 13px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .panel-level1 .hero-body h3 {
    font-family: 'Bangers', cursive;
    font-size: 24px;
    line-height: 1.2;
    margin-bottom: 6px;
    letter-spacing: 0.5px;
  }
  .panel-level1 .hero-body h3 a { color: var(--ink); text-decoration: none; }
  .panel-level1 .hero-body h3 a:hover { text-decoration: underline; }
  .panel-level1 .hero-body .excerpt { font-size: 15px; color: #555; line-height: 1.6; margin-bottom: 8px; }
  .panel-level1 .hero-meta { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; font-size: 12px; color: #999; }
  .panel-level1 .member-tag {
    position: absolute;
    top: 10px;
    right: 10px;
    background: var(--panel-bg);
    border: 2px solid var(--ink);
    border-radius: 20px;
    padding: 2px 10px 2px 6px;
    font-size: 12px;
    font-weight: bold;
    display: flex;
    align-items: center;
    gap: 4px;
    box-shadow: 2px 2px 0 rgba(0,0,0,0.3);
  }
  .member-tag .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .source-badge {
    position: absolute;
    bottom: 8px;
    right: 8px;
    background: rgba(0,0,0,0.7);
    color: #fff;
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 10px;
    font-family: sans-serif;
  }
  .level-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--red);
    color: #fff;
    font-family: 'Bangers', cursive;
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 8px;
    letter-spacing: 1px;
    box-shadow: 2px 2px 0 rgba(0,0,0,0.3);
  }

  /* ===== LEVEL 2: FEATURE PANELS ===== */
  .level2-row { display: flex; gap: 10px; }
  .panel-level2 {
    flex: 1;
    background: var(--panel-bg);
    border: 3px solid var(--ink);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 4px 4px 0 var(--shadow-color);
    cursor: pointer;
    transition: transform 0.15s;
  }
  .panel-level2:hover { transform: translate(-1px, -1px); box-shadow: 5px 5px 0 var(--shadow-color); }
  .panel-level2 .feat-visual {
    height: 110px;
    position: relative;
    overflow: hidden;
  }
  .panel-level2 .feat-visual img { width: 100%; height: 110px; object-fit: cover; display: block; border-bottom: 2px solid var(--ink); }
  /* L2 fallback visual when no image */
  .feat-visual-fallback {
    height: 110px;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 2px solid var(--ink);
    background-image: repeating-linear-gradient(45deg, transparent, transparent 8px, rgba(255,255,255,0.15) 8px, rgba(255,255,255,0.15) 16px);
  }
  .feat-visual-fallback .fallback-emoji { font-size: 42px; opacity: 0.9; filter: drop-shadow(2px 2px 0 rgba(0,0,0,0.2)); }
  .feat-visual-fallback .member-tag { position: absolute; top: 6px; right: 6px; }
  .panel-level2 .feat-body { padding: 10px 12px; }
  .panel-level2 .feat-body .category { font-family: 'Bangers', cursive; font-size: 11px; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 2px; }
  .panel-level2 .feat-body h3 { font-family: 'Bangers', cursive; font-size: 15px; line-height: 1.25; letter-spacing: 0.3px; margin-bottom: 4px; }
  .panel-level2 .feat-body h3 a { color: var(--ink); text-decoration: none; }
  .panel-level2 .feat-body .feat-excerpt { font-size: 13px; color: #666; line-height: 1.5; }

  /* ===== LEVEL 3: COMPACT PANELS ===== */
  .panel-level3 {
    background: var(--panel-bg);
    border: 3px solid var(--ink);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 3px 3px 0 var(--shadow-color);
    cursor: pointer;
    transition: transform 0.15s;
  }
  .panel-level3:hover { transform: translate(-1px, -1px); }
  .panel-level3 .compact-body {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
  }
  .panel-level3 .member-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 2px solid var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }
  .panel-level3 h4 { font-family: 'Bangers', cursive; font-size: 14px; flex: 1; letter-spacing: 0.3px; }
  .panel-level3 h4 a { color: var(--ink); text-decoration: none; }
  .panel-level3 .tag { font-size: 10px; background: #f0f0f0; padding: 2px 8px; border-radius: 4px; color: #888; font-family: sans-serif; white-space: nowrap; }

  /* ===== SHARED: EXPAND/COLLAPSE ===== */
  .expand-hint { font-size: 11px; color: #bbb; text-align: left; padding: 0 16px 8px; font-family: sans-serif; }
  .expand-hint::before { content: '▼ '; }
  .expanded .expand-hint::before { content: '▲ '; }
  .panel-detail {
    display: none;
    padding: 0 16px 14px;
    font-size: 14px;
    color: #555;
    line-height: 1.7;
    border-top: 2px dashed #eee;
    margin-top: 2px;
    padding-top: 10px;
  }
  .panel-detail.open { display: block; }
  .panel-detail .read-more {
    display: inline-block;
    margin-top: 8px;
    font-family: 'Bangers', cursive;
    font-size: 14px;
    color: var(--blue);
    text-decoration: none;
    border-bottom: 2px solid var(--blue);
    letter-spacing: 1px;
  }
  .panel-detail .read-more:hover { color: var(--red); border-color: var(--red); }

  /* ===== SPECIAL SECTIONS ===== */
  .discovery-panel { background: #f4ecf7; border-color: var(--purple); border-style: dashed; }
  .discovery-panel .bridge-text { font-size: 12px; font-weight: bold; color: var(--purple); margin-bottom: 4px; }
  .puzzle-panel { background: #fef9e7; border-color: var(--yellow); }
  .puzzle-panel .panel-body { text-align: center; }
  .puzzle-panel h3 { color: var(--orange); }
  .history-panel { background: #fef3e2; border-color: var(--orange); }
  .survey-panel { background: linear-gradient(135deg, #eaf2f8, #d5e8f0); border-color: var(--blue); text-align: center; padding: 20px; }
  .survey-panel h3 { color: var(--blue); margin-bottom: 8px; }
  .survey-panel p { font-size: 17px; font-weight: bold; }
  .wa-btn {
    display: inline-block;
    margin-top: 10px;
    background: #25D366;
    color: #fff;
    font-family: 'Bangers', cursive;
    font-size: 16px;
    padding: 8px 24px;
    border-radius: 30px;
    border: 2px solid var(--ink);
    text-decoration: none;
    box-shadow: 3px 3px 0 var(--shadow-color);
    letter-spacing: 1px;
  }
  .wa-btn:hover { transform: translate(-1px,-1px); box-shadow: 4px 4px 0 var(--shadow-color); }
  .closer {
    background: linear-gradient(135deg, #e8f8f5, #d5f5e3);
    border: 3px solid var(--green);
    border-radius: 14px;
    padding: 16px 20px;
    margin-top: 12px;
    box-shadow: 4px 4px 0 rgba(0,0,0,0.1);
    text-align: center;
  }
  .closer h3 { font-family: 'Bangers', cursive; font-size: 18px; color: var(--green); margin-bottom: 6px; }
  .closer p { font-size: 15px; color: #555; }
  .ltr { direction: ltr; text-align: left; }
  .family-strip {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 12px;
    padding: 10px;
    background: var(--panel-bg);
    border: 3px solid var(--ink);
    border-radius: 12px;
    box-shadow: 3px 3px 0 var(--shadow-color);
  }
  .family-strip .member-chip {
    display: flex; align-items: center; gap: 4px;
    font-size: 12px; font-weight: bold;
    padding: 4px 10px; border-radius: 20px; border: 2px solid var(--ink);
  }
  .family-strip .member-chip .count { font-family: 'Bangers', cursive; font-size: 14px; }
  .footer-strip { text-align: center; padding: 16px; font-size: 12px; color: #999; }
  .footer-strip .family-icons { font-size: 20px; margin-bottom: 4px; letter-spacing: 6px; }
  .mini-mascot { display: inline-block; vertical-align: middle; margin: 0 4px; }

  /* ===== PERSONAL CORNERS ===== */
  .member-corner { display: flex; flex-direction: column; gap: 10px; margin-bottom: 4px; }
  .corner-header {
    display: flex; align-items: center; gap: 10px;
    background: var(--panel-bg);
    border: 3px solid var(--ink);
    border-radius: 12px;
    padding: 8px 14px;
    box-shadow: 3px 3px 0 var(--shadow-color);
  }
  .corner-icon {
    width: 40px; height: 40px; border-radius: 10px;
    border: 2px solid var(--ink);
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; color: #fff; flex-shrink: 0;
  }
  .corner-header h2 { font-family: 'Bangers', cursive; font-size: 19px; letter-spacing: 0.5px; }
  .panel-level2-solo { flex: 1; }

  /* ===== HERO SVG SCENE (no-image fallback backdrop) ===== */
  .hero-scene { width: 100%; height: 220px; display: block; border-bottom: 3px solid var(--ink); }
  .hero-character-slot { position: absolute; bottom: 10px; left: 10px; z-index: 2; }

  /* ===== CHARACTER SLOTS (character_html() output — PNG-or-emoji, §2.1/§2.7) ===== */
  .character-emoji, .character-img { display: inline-block; }
  .character-hero-greeting.character-emoji { font-size: 64px; filter: drop-shadow(2px 2px 0 rgba(0,0,0,0.25)); }
  .character-hero-greeting.character-img { width: 90px; height: 120px; object-fit: contain; }
  .character-thinking.character-emoji, .character-pointing.character-emoji, .character-reading.character-emoji { font-size: 26px; vertical-align: middle; }
  .character-thinking.character-img, .character-pointing.character-img, .character-reading.character-img { width: 34px; height: 34px; object-fit: contain; vertical-align: middle; }
  .character-goodbye.character-emoji { font-size: 40px; }
  .character-goodbye.character-img { width: 56px; height: 56px; object-fit: contain; }

  /* ===== YOUTUBE THUMBNAIL TREATMENT ===== */
  .yt-thumb { position: relative; }
  .yt-thumb::after { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 48px; height: 48px; background: rgba(255,0,0,0.85); border-radius: 12px; }
  .yt-play { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 0; height: 0; border-top: 12px solid transparent; border-bottom: 12px solid transparent; border-left: 20px solid white; z-index: 2; margin-left: 3px; }

  /* ===== VIEWING ===== */
  .viewing-panel { background: #eaf6fb; border-color: var(--blue); }
  .viewing-pick-label { font-family: 'Bangers', cursive; font-size: 13px; letter-spacing: 0.5px; color: var(--blue); margin-bottom: 4px; }
  .viewing-title { font-family: 'Bangers', cursive; font-size: 17px; margin-bottom: 6px; }
  .viewing-badges { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 4px; }
  .viewing-badge { font-size: 11px; font-family: sans-serif; padding: 2px 8px; border-radius: 10px; background: #eee; color: #666; }
  .viewing-badge-ok { background: #e6f5ed; color: var(--green); }
  .viewing-badge-warn { background: #fce8ec; color: var(--red); }
  .viewing-note { font-size: 13px; color: #666; margin-top: 4px; }

  /* ===== FAMILY TABLE ===== */
  .family-table-panel { background: #fdf0e3; border-color: var(--orange); }
  .family-table-prompt { font-size: 15px; line-height: 1.7; }
  .family-table-item { padding: 8px 0; border-bottom: 1px dashed #eee; }
  .family-table-item:last-child { border-bottom: none; }
  .family-table-who { font-family: 'Bangers', cursive; font-size: 12px; color: var(--orange); letter-spacing: 0.5px; }
  .family-table-headline { font-size: 15px; font-weight: bold; margin-top: 2px; }
  .family-table-summary { font-size: 13px; color: #666; margin-top: 2px; }

  /* ===== FROM OUR SHELF ===== */
  .shelf-panel { background: #f3ede3; border-color: #8B4513; }
  .shelf-icon { flex-shrink: 0; }
  .shelf-title { font-family: 'Bangers', cursive; font-size: 16px; line-height: 1.3; }
  .shelf-title-en { font-size: 12px; color: #888; font-style: italic; margin-top: 1px; }
  .shelf-meta { font-size: 12px; color: #888; margin-top: 3px; }
  .shelf-blurb { font-size: 13px; color: #666; margin-top: 6px; line-height: 1.6; }

  /* ===== EXTENDED FAMILY ===== */
  .extended-family-panel { background: #fdeef2; border-color: var(--maayan); }
  .ext-family-item { padding: 8px 0; border-bottom: 1px dashed #eee; }
  .ext-family-item:last-child { border-bottom: none; }
  .ext-family-name { font-family: 'Bangers', cursive; font-size: 14px; }
  .ext-family-relation { font-family: 'Patrick Hand', cursive; font-size: 12px; color: #888; font-weight: normal; }
  .ext-family-headline { font-size: 14px; margin-top: 2px; }
  .ext-family-pointer { font-size: 13px; color: #666; margin-top: 3px; line-height: 1.6; }

  /* ===== INLINE EMOJI RATING (footer) ===== */
  .rating-row { display: flex; justify-content: center; gap: 8px; margin: 10px 0; flex-wrap: wrap; }
  .rate-btn {
    display: flex; flex-direction: column; align-items: center; gap: 2px;
    text-decoration: none;
    padding: 8px 14px;
    border-radius: 12px;
    background: var(--panel-bg);
    border: 2px solid var(--ink);
    box-shadow: 2px 2px 0 var(--shadow-color);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .rate-btn:hover { transform: translate(-1px, -1px); box-shadow: 3px 3px 0 var(--shadow-color); }
  .rate-btn .emoji { font-size: 24px; }
  .rate-btn .label { font-size: 10px; color: #888; font-family: 'Patrick Hand', cursive; }

  /* ===== PLACEHOLDER SECTIONS (BUILD_DIRECTIVE D1) ===== */
  .placeholder-block {
    border: 3px dashed var(--orange);
    background: #fffbf0;
    border-radius: 10px;
    padding: 20px;
    text-align: center;
    font-family: 'Bangers', cursive;
    font-size: 18px;
    color: var(--orange);
    letter-spacing: 1px;
    margin: 4px 0;
  }
</style>
</head>
<body>
<div class="page">

{% set member_colors = {'nimrod': 'var(--nimrod)', 'michal': 'var(--michal)', 'shaked': 'var(--shaked)', 'maayan': 'var(--maayan)', 'tzlil': 'var(--tzlil)'} %}
{% set member_bg = {'nimrod': 'var(--nimrod-bg)', 'michal': 'var(--michal-bg)', 'shaked': 'var(--shaked-bg)', 'maayan': 'var(--maayan-bg)', 'tzlil': 'var(--tzlil-bg)'} %}
{% set member_emoji = {'nimrod': '⛵', 'michal': '🌿', 'shaked': '⚗️', 'maayan': '🎪', 'tzlil': '🧮'} %}
{% set member_names = {'nimrod': 'נימרוד', 'michal': 'מיכל', 'shaked': 'Shaked', 'maayan': 'יויו', 'tzlil': 'צליל'} %}

  <!-- ===== COVER ===== -->
  <div class="cover">
    <div class="cover-top">
      <div class="masthead">Family Newsletter!</div>
      <div class="subtitle">בית ולד</div>
      <div class="edition-badge">{{ neo.date_formatted or neo.date }} &bull; #{{ edition_number or '1' }}</div>
    </div>
    <div class="cover-body">
      <div class="mascot-bubble">
        {{ neo.greeting }}
      </div>
      <div class="mascot-name">{{ neo.metadata.get('character_emoji', '🎩') }} {{ neo.metadata.get('character_name', 'Cat in the Hat') }} &mdash; {{ neo.metadata.get('character_month', '') }}</div>
    </div>
  </div>

  <!-- ===== OPENER (פתיח) — Style 4: warm, personal ===== -->
  {% if neo.metadata.get('opener_text') %}
  <div class="opener">
    <h3>☀️ מה מחכה לכם השבוע</h3>
    <p>{{ neo.metadata.get('opener_text') | safe }}</p>
  </div>
  {% endif %}

  <!-- ===== FAMILY STRIP ===== -->
  {% if neo.member_sections %}
  <div class="family-strip">
    {% for section in neo.member_sections %}
    {% set member_count = section['items']|length %}
    <div class="member-chip" style="background:{{ member_bg.get(section.member_id, 'var(--panel-bg)') }};">
      <span class="dot" style="background:{{ member_colors[section.member_id] }};width:8px;height:8px;border-radius:50%;"></span>
      {{ member_names.get(section.member_id, section.member_id) }} <span class="count">{{ member_count }}</span>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <!-- ===== WEEKLY WEATHER FORECAST ===== -->
  {% if neo.metadata.get('weather') %}
  <div class="weather-section" id="weather-section" onclick="toggleWeather()">
    <div class="weather-header">
      <span>🌤️ תחזית שבועית</span>
      <span class="toggle-arrow">▼</span>
    </div>
    <!-- Overview row: quick glance at all locations -->
    <div class="weather-overview">
      {% for w in neo.metadata['weather'] %}
      <div class="weather-mini{% if w.get('wind_alert') %} wind-highlight{% endif %}">
        <div class="w-icon">{{ w.get('icon', '🌤️') }}</div>
        <div class="w-temp">{{ w.get('temp', '--') }}{% if w.get('is_temp', true) and '°' not in (w.get('temp', '')|string) %}°{% endif %}</div>
        <div class="w-city">{{ w.get('city', '') }}</div>
      </div>
      {% endfor %}
    </div>
    <!-- Detailed per-location (expanded) -->
    <div class="weather-details">
      {% for w in neo.metadata['weather'] %}
      <div class="weather-loc">
        <div class="weather-loc-header">
          <span class="loc-icon">{{ w.get('icon', '🌤️') }}</span>
          <span>{{ w.get('city', '') }} — {{ w.get('temp', '') }}{% if w.get('is_temp', true) and '°' not in (w.get('temp', '')|string) %}°{% endif %}</span>
        </div>
        {% if w.get('daily') %}
        <div class="weather-graph">
          {% for day in w['daily'] %}
          {% set bar_h = ((day.get('high', 25) - 5) * 2)|int %}
          {% if bar_h < 6 %}{% set bar_h = 6 %}{% endif %}
          {% if bar_h > 46 %}{% set bar_h = 46 %}{% endif %}
          <div class="bar" style="height:{{ bar_h }}px; background: linear-gradient(to top, {{ member_colors.get('nimrod', 'var(--blue)') }}, {{ '#e74c3c' if day.get('high', 25) > 30 else '#3498db' }});">
            <span class="bar-label">{{ day.get('high', '') }}°</span>
            <span class="day-label">{{ day.get('day', '') }}</span>
          </div>
          {% endfor %}
        </div>
        {% endif %}
        <div class="weather-loc-desc">{{ w.get('description', '') }}{% if w.get('week_summary') %}<br>{{ w.get('week_summary') }}{% endif %}</div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <div class="grid">

  <!-- ===== PERSONAL CORNERS ×5 (replaces pooled HERO/FEATURE/COMPACT grid) ===== -->
  {% for section in neo.member_sections %}
  {% set corner_items = section['items'] %}
  {% if corner_items %}
  {% set corner_lang_cls = ' ltr' if section.language == 'en' else '' %}
  <div class="section-sep">{{ member_emoji.get(section.member_id, '📰') }} {{ member_names.get(section.member_id, section.member_id) }} {{ member_emoji.get(section.member_id, '📰') }}</div>

  <div class="member-corner{{ corner_lang_cls }}">
    <div class="corner-header" style="border-color:{{ member_colors.get(section.member_id, 'var(--ink)') }};">
      <div class="corner-icon" style="background:{{ member_colors.get(section.member_id, '#888') }};">{{ member_emoji.get(section.member_id, '📰') }}</div>
      <h2>{% if section.language == 'en' %}{{ section.member_name_en }}&#39;s Corner{% else %}הפינה של {{ member_names.get(section.member_id, section.member_id) }}{% endif %}</h2>
    </div>

    {% set corner_hero = corner_items[0] %}
    {% set corner_rest = corner_items[1:] %}
    {% set hero_is_yt = 'youtube.com' in (corner_hero.url or '') or 'youtu.be' in (corner_hero.url or '') %}

    <div class="panel-level1{% if corner_hero.language == 'en' %} ltr{% endif %}" onclick="togglePanel(this)">
      <div class="hero-visual{% if hero_is_yt and corner_hero.image_url %} yt-thumb{% endif %}"{% if not corner_hero.image_url %} style="background: linear-gradient(135deg, {{ member_bg.get(section.member_id, 'var(--nimrod-bg)') }}, #d6eaf8);"{% endif %}>
        {% if corner_hero.image_url %}
        <img src="{{ corner_hero.image_url }}" alt="{{ corner_hero.title }}" loading="lazy">
        {% if hero_is_yt %}<span class="yt-play"></span>{% endif %}
        {% else %}
        <svg class="hero-scene" viewBox="0 0 640 380" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="corner-dots-{{ section.member_id }}" width="8" height="8" patternUnits="userSpaceOnUse">
              <circle cx="4" cy="4" r="1" fill="rgba(0,0,0,0.06)"/>
            </pattern>
            <linearGradient id="corner-sky-{{ section.member_id }}" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#87CEEB"/>
              <stop offset="60%" stop-color="#E0F0FF"/>
              <stop offset="100%" stop-color="#F5E6D3"/>
            </linearGradient>
            <linearGradient id="corner-sea-{{ section.member_id }}" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#2471a3"/>
              <stop offset="100%" stop-color="#1a5276"/>
            </linearGradient>
          </defs>
          <rect width="640" height="380" fill="url(#corner-sky-{{ section.member_id }})"/>
          <rect width="640" height="380" fill="url(#corner-dots-{{ section.member_id }})"/>
          <g opacity="0.7">
            <ellipse cx="120" cy="60" rx="50" ry="22" fill="white"/>
            <ellipse cx="95" cy="55" rx="30" ry="18" fill="white"/>
            <ellipse cx="145" cy="55" rx="35" ry="20" fill="white"/>
            <ellipse cx="450" cy="80" rx="40" ry="18" fill="white"/>
            <ellipse cx="425" cy="75" rx="25" ry="14" fill="white"/>
            <ellipse cx="475" cy="75" rx="30" ry="16" fill="white"/>
          </g>
          <circle cx="560" cy="70" r="35" fill="#f39c12" opacity="0.9"/>
          <circle cx="560" cy="70" r="28" fill="#f9e79f"/>
          <path d="M0 240 Q80 225 160 240 Q240 255 320 240 Q400 225 480 240 Q560 255 640 240 L640 380 L0 380 Z" fill="url(#corner-sea-{{ section.member_id }})"/>
          <path d="M0 260 Q80 250 160 260 Q240 270 320 260 Q400 250 480 260 Q560 270 640 260" fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
          <path d="M0 280 Q80 272 160 280 Q240 288 320 280 Q400 272 480 280 Q560 288 640 280" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
          <g transform="translate(480, 210)">
            <path d="M0 0 L-8 30 L8 30 Z" fill="white" stroke="#2c2c2c" stroke-width="1"/>
            <line x1="0" y1="0" x2="0" y2="30" stroke="#2c2c2c" stroke-width="1.5"/>
            <path d="M-12 30 Q0 28 12 30" fill="#5a3a1a" stroke="#2c2c2c" stroke-width="1"/>
          </g>
          <g transform="translate(350, 140)">
            <path d="M0 -20 L15 0 L0 20 L-15 0 Z" fill="#e74c3c" stroke="#2c2c2c" stroke-width="1.5" opacity="0.8"/>
            <path d="M0 20 Q10 35 5 50 Q0 65 -5 80" fill="none" stroke="#2c2c2c" stroke-width="1" opacity="0.5"/>
          </g>
          <g transform="translate(400, 250)">
            <path d="M0 0 Q5 -15 15 -12 Q25 -10 20 0" fill="#87CEEB" stroke="#2c2c2c" stroke-width="1.5"/>
            <circle cx="18" cy="-8" r="1.5" fill="#2c2c2c"/>
            <path d="M-5 2 Q0 -5 5 2" fill="none" stroke="white" stroke-width="1" opacity="0.6"/>
          </g>
        </svg>
        {% endif %}
        <div class="source-badge">{{ corner_hero.source_name }}</div>
        <div class="level-badge">HERO</div>
        <div class="hero-character-slot">{{ character_html('hero-greeting', current_month) | safe }}</div>
      </div>
      <div class="hero-body">
        <div class="category" style="color: {{ member_colors.get(section.member_id, 'var(--ink)') }};">{{ corner_hero.category }}</div>
        <h3><a href="{{ corner_hero.url }}">{{ corner_hero.title }}</a></h3>
        <div class="excerpt">{{ corner_hero.summary }}</div>
        <div class="hero-meta">
          {{ corner_hero.source_name }} &bull; {{ neo.date }} &bull; <span style="background:#eee;padding:1px 6px;border-radius:4px;font-size:10px;">{{ corner_hero.language|upper }}</span>
        </div>
      </div>
      <div class="expand-hint">לחצו לפרטים</div>
      <div class="panel-detail">
        <p>{{ corner_hero.get('full_text', corner_hero.summary) }}</p>
        <a href="{{ corner_hero.url }}" class="read-more">{% if corner_hero.language == 'en' %}Read more &rarr;{% else %}למאמר המלא &larr;{% endif %}</a>
      </div>
    </div>

    {% if corner_rest %}
    {% for item in corner_rest %}
      {% set item_is_yt = 'youtube.com' in (item.url or '') or 'youtu.be' in (item.url or '') %}
      {% if loop.index is odd %}
    <div class="level2-row">
      {% endif %}
      <div class="panel-level2{% if item.language == 'en' %} ltr{% endif %}{% if loop.index == loop.length and loop.index is odd %} panel-level2-solo{% endif %}" onclick="togglePanel(this)">
        {% if item.image_url %}
        <div class="feat-visual{% if item_is_yt %} yt-thumb{% endif %}">
          <img src="{{ item.image_url }}" alt="{{ item.title }}" loading="lazy">
          {% if item_is_yt %}<span class="yt-play"></span>{% endif %}
        </div>
        {% else %}
        <div class="feat-visual-fallback" style="background-color: {{ member_bg.get(section.member_id, '#f0f0f0') }};">
          <span class="fallback-emoji">{{ member_emoji.get(section.member_id, '📰') }}</span>
        </div>
        {% endif %}
        <div class="feat-body">
          <div class="category" style="color:{{ member_colors.get(section.member_id, 'var(--ink)') }};">{{ item.category }}</div>
          <h3><a href="{{ item.url }}">{{ item.title }}</a></h3>
          <div class="feat-excerpt">{{ item.summary }}</div>
        </div>
        <div class="expand-hint">{% if item.language == 'en' %}tap for more{% else %}לחצו לפרטים{% endif %}</div>
        <div class="panel-detail">
          <p>{{ item.get('full_text', item.summary) }}</p>
          <a href="{{ item.url }}" class="read-more">{% if item.language == 'en' %}Read more &rarr;{% else %}למאמר &larr;{% endif %}</a>
        </div>
      </div>
      {% if loop.index is even or loop.last %}
    </div>
      {% endif %}
    {% endfor %}
    {% endif %}
  </div>
  {% endif %}
  {% endfor %}

  <!-- ===== DISCOVERY ===== -->
  {% if neo.discovery %}
  <div class="section-sep">🔮 גילוי 🔮</div>

  {% for item in neo.discovery %}
  <div class="panel-level3 discovery-panel" onclick="togglePanel(this)" style="border-style:dashed;">
    <div style="padding: 12px 14px;">
      <div class="bridge-text"><span class="mini-mascot character-pointing">{{ character_html('pointing', current_month) | safe }}</span> {{ item.bridge_text }}</div>
      <h4 style="font-family:'Bangers',cursive; font-size:16px;"><a href="{{ item.url }}" style="color:var(--ink); text-decoration:none;">{{ item.title }}</a></h4>
      {% if item.summary %}<p style="font-size:13px; color:#666; margin-top:4px;">{{ item.summary[:120] }}{% if item.summary|length > 120 %}...{% endif %}</p>{% endif %}
    </div>
    <div class="expand-hint">לחצו לפרטים</div>
    <div class="panel-detail">
      <p>{{ item.summary }}</p>
      <a href="{{ item.url }}" class="read-more">למאמר המלא &larr;</a>
    </div>
  </div>
  {% endfor %}
  {% endif %}

  <!-- ===== VIEWING (מה רואים השבוע) ===== -->
  {% set viewing = neo.metadata.get('viewing', {}) %}
  {% set viewing_fp = viewing.get('family_pick') or {} %}
  {% set viewing_pp = viewing.get('personal_pick') or {} %}
  {% set viewing_is_placeholder = (viewing_fp.get('title', '') == '🚧 בהכנה' or ('🚧 בהכנה' in (viewing_fp.get('title', '') or ''))) %}
  {% if viewing_fp or viewing_pp or viewing_is_placeholder %}
  <div class="section-sep">🍿 מה רואים השבוע 🍿</div>

  <div class="panel-level3 viewing-panel">
    <div style="padding: 14px 16px;">
      {% if viewing_is_placeholder %}
      <div class="placeholder-block">🚧 בהכנה — מה רואים השבוע</div>
      {% else %}
      {% if viewing_fp %}
      <div class="viewing-pick">
        <div class="viewing-pick-label">👨‍👩‍👧‍👦 בחירת המשפחה</div>
        <h4 class="viewing-title">{{ viewing_fp.get('title', '') }}</h4>
        <div class="viewing-badges">
          {% if viewing_fp.get('platform') %}<span class="viewing-badge">{{ viewing_fp['platform'] }}</span>{% endif %}
          {% if viewing_fp.get('hebrew_subs') %}<span class="viewing-badge viewing-badge-ok">כתוביות עברית ✓</span>{% endif %}
          {% if viewing_fp.get('available_il') == false %}<span class="viewing-badge viewing-badge-warn">⚠️ בדקו זמינות בישראל</span>{% endif %}
        </div>
        {% if viewing_fp.get('note') %}<p class="viewing-note">{{ viewing_fp['note'] }}</p>{% endif %}
      </div>
      {% endif %}
      {% if viewing_pp %}
      <div class="viewing-pick"{% if viewing_fp %} style="border-top:2px dashed #eee; margin-top:10px; padding-top:10px;"{% endif %}>
        <div class="viewing-pick-label" style="color:{{ member_colors.get(viewing_pp.get('member_id'), 'var(--ink)') }};">{{ member_emoji.get(viewing_pp.get('member_id'), '🎬') }} הבחירה האישית של {{ member_names.get(viewing_pp.get('member_id'), '') }}</div>
        <h4 class="viewing-title">{{ viewing_pp.get('title', '') }}</h4>
        <div class="viewing-badges">
          {% if viewing_pp.get('platform') %}<span class="viewing-badge">{{ viewing_pp['platform'] }}</span>{% endif %}
          {% if viewing_pp.get('hebrew_subs') %}<span class="viewing-badge viewing-badge-ok">כתוביות עברית ✓</span>{% endif %}
          {% if viewing_pp.get('available_il') == false %}<span class="viewing-badge viewing-badge-warn">⚠️ בדקו זמינות בישראל</span>{% endif %}
        </div>
        {% if viewing_pp.get('note') %}<p class="viewing-note">{{ viewing_pp['note'] }}</p>{% endif %}
      </div>
      {% endif %}
      {% endif %}
    </div>
  </div>
  {% endif %}

  <!-- ===== FAMILY TABLE (שולחן שישי) ===== -->
  {% set family_table_text = neo.metadata.get('family_table_text', '') %}
  {% set ft_is_placeholder = (family_table_text == '🚧 בהכנה' or '🚧 בהכנה' in (family_table_text or '')) %}
  {% if neo.family_content or family_table_text %}
  <div class="section-sep">🍽️ שולחן שישי 🍽️</div>

  <div class="panel-level3 family-table-panel">
    <div style="padding: 14px 16px;">
      {% if ft_is_placeholder %}
      <div class="placeholder-block">🚧 בהכנה — שולחן שישי</div>
      {% else %}
      {% if family_table_text %}
      <p class="family-table-prompt">{{ family_table_text | safe }}</p>
      {% endif %}
      {% if neo.family_content %}
      <div class="family-table-items"{% if family_table_text %} style="margin-top:10px; padding-top:10px; border-top:2px dashed #eee;"{% endif %}>
        {% for fc in neo.family_content %}
        <div class="family-table-item">
          <div class="family-table-who">{{ fc.get('member_name', '') }} שיתפ/ה</div>
          <div class="family-table-headline">{{ fc.get('headline', '') }}</div>
          {% if fc.get('summary') %}<p class="family-table-summary">{{ fc['summary'] }}</p>{% endif %}
          {% if fc.get('link_url') %}<a href="{{ fc['link_url'] }}" class="read-more">קישור &larr;</a>{% endif %}
        </div>
        {% endfor %}
      </div>
      {% endif %}
      {% endif %}
    </div>
  </div>
  {% endif %}

  <!-- ===== FROM OUR SHELF (מהמדף שלנו) ===== -->
  {% set shelf = neo.metadata.get('shelf_pick', {}) %}
  {% set shelf_is_placeholder = ('🚧 בהכנה' in (shelf.get('blurb', '') or '') or '🚧 בהכנה' in (shelf.get('title_he', '') or '')) %}
  {% if shelf %}
  <div class="section-sep">📚 מהמדף שלנו 📚</div>

  <div class="panel-level3 shelf-panel">
    {% if shelf_is_placeholder %}
    <div style="padding: 14px 16px;">
      <div class="placeholder-block">🚧 בהכנה — מהמדף שלנו</div>
    </div>
    {% else %}
    <div style="padding: 14px 16px; display: flex; gap: 12px; align-items: flex-start;">
      <div class="shelf-icon character-reading">{{ character_html('reading', current_month) | safe }}</div>
      <div>
        <h4 class="shelf-title">{{ shelf.get('title_he', shelf.get('title_en', '')) }}</h4>
        {% if shelf.get('title_en') and shelf.get('title_he') %}<div class="shelf-title-en">{{ shelf['title_en'] }}</div>{% endif %}
        <div class="shelf-meta">{{ shelf.get('author', '') }}{% if shelf.get('category') %} &bull; {{ shelf['category'] }}{% endif %}</div>
        {% if shelf.get('blurb') %}<p class="shelf-blurb">{{ shelf['blurb'] }}</p>{% endif %}
        {% if shelf.get('member_id') %}
        <div class="viewing-badge" style="background:{{ member_bg.get(shelf['member_id'], '#f0f0f0') }}; color:{{ member_colors.get(shelf['member_id'], 'var(--ink)') }}; margin-top:6px;">{{ member_emoji.get(shelf['member_id'], '📖') }} מדף {{ member_names.get(shelf['member_id'], '') }}</div>
        {% endif %}
      </div>
    </div>
    {% endif %}
  </div>
  {% endif %}

  <!-- ===== PUZZLE ===== -->
  {% if neo.trivia.get('puzzle') %}
  <div class="section-sep">🧩 חידה 🧩</div>

  <div class="panel-level3 puzzle-panel" style="border-color:var(--yellow);">
    <div style="padding: 14px 16px; text-align:center;">
      <h3 style="font-family:'Bangers',cursive; font-size:18px; color:var(--orange); margin-bottom:8px;">
        <span class="mini-mascot character-thinking">{{ character_html('thinking', current_month) | safe }}</span>
        חידת השבוע
      </h3>
      <p style="font-size:16px; line-height:1.8; white-space:pre-line;">{{ neo.trivia['puzzle'] }}{% if neo.trivia.get('answer') %}<br><br><strong style="color:var(--orange);">תשובה מהשבוע שעבר: {{ neo.trivia['answer'] }}</strong>{% endif %}</p>
    </div>
  </div>
  {% endif %}

  <!-- ===== EXTENDED FAMILY (מהמשפחה המורחבת) ===== -->
  {% set extended_family = neo.metadata.get('extended_family', []) %}
  {% set ef_is_placeholder = (extended_family|length == 1 and extended_family[0].get('headline', '') == '🚧 בהכנה') %}
  {% if extended_family %}
  <div class="section-sep">👨‍👩‍👧 מהמשפחה המורחבת 👨‍👩‍👧</div>

  <div class="panel-level3 extended-family-panel">
    <div style="padding: 14px 16px;">
      {% if ef_is_placeholder %}
      <div class="placeholder-block">🚧 בהכנה — מהמשפחה המורחבת</div>
      {% else %}
      {% for ef in extended_family %}
      <div class="ext-family-item">
        <div class="ext-family-name">{{ ef.get('name', '') }}{% if ef.get('relation') %} <span class="ext-family-relation">&middot; {{ ef['relation'] }}</span>{% endif %}</div>
        <div class="ext-family-headline">{{ ef.get('headline', '') }}</div>
        {% if ef.get('pointer_text') %}<p class="ext-family-pointer">{{ ef['pointer_text'] }}</p>{% endif %}
        {% if ef.get('link_url') %}<a href="{{ ef['link_url'] }}" class="read-more">לצפייה &larr;</a>{% endif %}
      </div>
      {% endfor %}
      {% endif %}
    </div>
  </div>
  {% endif %}

  <!-- ===== TODAY IN HISTORY ===== -->
  {% if neo.trivia.get('history') %}
  <div class="section-sep">📜 היום 📜</div>

  <div class="panel-level3 history-panel" style="border-color:var(--orange);">
    <div style="padding: 12px 14px;">
      <div style="font-family:'Bangers',cursive; font-size:13px; color:var(--orange); letter-spacing:1px; margin-bottom:4px;">📜 היום בהיסטוריה</div>
      <p style="font-size:14px;">{{ neo.trivia['history'] }}</p>
    </div>
  </div>
  {% endif %}

  <!-- ===== SURVEY ===== -->
  {% if neo.survey_question %}
  <div class="section-sep">💬 משוב 💬</div>

  <div class="panel-level3 survey-panel" style="border-color:var(--blue); text-align:center;">
    <div style="padding:16px;">
      <h3 style="font-family:'Bangers',cursive; font-size:18px; color:var(--blue); margin-bottom:8px;">
        <span class="mini-mascot" style="font-size:24px;">{{ neo.metadata.get('character_emoji', '🎩') }}</span>
        שאלת השבוע
      </h3>
      <p style="font-size:17px; font-weight:bold;">{{ neo.survey_question }}</p>
      <div style="font-size:12px; color:#888; margin-top:8px;">
        {% set wa_link = neo.metadata.get('whatsapp_group_link', '') %}
        {% if wa_link %}
        <a href="{{ wa_link }}" style="color:#25D366; text-decoration:none; font-weight:bold;">ענו בקבוצת וואטסאפ! 📱</a>
        {% elif neo.metadata.get('whatsapp_number') %}
        <a href="https://wa.me/{{ neo.metadata['whatsapp_number'] }}?text={{ neo.survey_question | urlencode }}" style="color:#25D366; text-decoration:none; font-weight:bold;">ענו בוואטסאפ! 📱</a>
        {% else %}
        ענו בקבוצת וואטסאפ! 📱
        {% endif %}
      </div>
    </div>
  </div>
  {% endif %}

  </div><!-- /grid -->

  <!-- ===== CLOSER (סגיר) — Style 4: warm ===== -->
  {% if neo.metadata.get('closer_text') %}
  <div class="closer">
    <h3>🌙 שבוע נפלא!</h3>
    <p>{{ neo.metadata.get('closer_text') | safe }}</p>
    <div style="margin-top:10px; text-align:center;" class="character-goodbye">
      {{ character_html('goodbye', current_month) | safe }}
    </div>
  </div>
  {% endif %}

  <!-- ===== FOOTER ===== -->
  <div class="footer-strip">
    <div class="family-icons">⛵ 🌿 ⚗️ 🎪 🧮</div>
    Family Newsletter &bull; #{{ edition_number or '1' }} &bull; {{ neo.date_formatted or neo.date }}
    <br><span style="font-family:'Patrick Hand',cursive; font-size:13px; color:#999;">עורכת: {{ neo.metadata.get('editor_name', 'צליל') }}</span>

    {% set footer_wa_link = neo.metadata.get('whatsapp_group_link', '') %}
    {% set footer_wa_number = neo.metadata.get('whatsapp_number', '') %}
    {% if footer_wa_link or footer_wa_number %}
    <div class="rating-row">
      {% set ratings = [
        {'emoji': '😍', 'label': 'מעולה', 'text': 'הניוזלטר השבוע: מעולה! 😍'},
        {'emoji': '😊', 'label': 'טוב', 'text': 'הניוזלטר השבוע: טוב 😊'},
        {'emoji': '😐', 'label': 'ככה ככה', 'text': 'הניוזלטר השבוע: ככה ככה 😐'},
        {'emoji': '👎', 'label': 'לא טוב', 'text': 'הניוזלטר השבוע: לא טוב 👎'}
      ] %}
      {% for r in ratings %}
      {% if footer_wa_number %}
      <a href="https://wa.me/{{ footer_wa_number }}?text={{ r.text | urlencode }}" class="rate-btn" id="rate-{{ loop.index }}"><span class="emoji">{{ r.emoji }}</span><span class="label">{{ r.label }}</span></a>
      {% else %}
      <a href="{{ footer_wa_link }}" class="rate-btn" id="rate-{{ loop.index }}"><span class="emoji">{{ r.emoji }}</span><span class="label">{{ r.label }}</span></a>
      {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    <br><span style="font-family:sans-serif; font-size:11px; color:#bbb; letter-spacing:0.5px;">by <strong style="color:#999;">AgentsOS</strong> @ nimrod.bio</span>
    <br><span style="font-family:monospace; font-size:10px; color:#ccc;">v{{ system_version or '3.0.0' }} &bull; built {{ build_timestamp or '' }}</span>
  </div>

</div><!-- /page -->

<script>
function togglePanel(el) {
  var detail = el.querySelector('.panel-detail');
  if (!detail) return;
  var isOpen = detail.classList.contains('open');
  document.querySelectorAll('.panel-detail.open').forEach(function(d) {
    d.classList.remove('open');
    d.parentElement.classList.remove('expanded');
  });
  if (!isOpen) {
    detail.classList.add('open');
    el.classList.add('expanded');
  }
}
function toggleWeather() {
  var sec = document.getElementById('weather-section');
  sec.classList.toggle('expanded');
}
</script>
</body>
</html>
