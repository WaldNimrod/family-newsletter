# Family Newsletter — Environment (copy to .env)
#
# Primary names below match Upress / server deployments. Legacy aliases in parentheses
# are still supported for local dev.

# --- Claude API (required for real newsletter copy; leave empty only for local mock / tests) ---
# https://console.anthropic.com/ — key format sk-ant-api03-...
ANTHROPIC_API_KEY=

# --- FTP upload (Upress: names say SFTP but port 21 = plain FTP) ---
UPRESS_SFTP_HOST=ftp.example.upress.link
UPRESS_SFTP_PORT=21
UPRESS_SFTP_USER=
UPRESS_SFTP_PASS=
# Remote folder for newsletter HTML (leading slash; no trailing slash)
UPRESS_UPLOAD_PATH=/agents/newsletter
# Domain only — path is derived from UPRESS_UPLOAD_PATH (no trailing slash)
UPRESS_PUBLIC_BASE=https://nimrod.bio

# Legacy FTP aliases (optional if UPRESS_* set):
# FTP_HOST= FTP_USER= FTP_PASS= FTP_PORT=21 FTP_PATH=

# --- SMTP (email fallback) ---
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
# 465 = SSL; 587 = STARTTLS (handled automatically)
EMAIL_SMTP_USER=
EMAIL_PASSWORD=
EMAIL_FROM=

# Legacy: SMTP_HOST SMTP_PORT SMTP_USER SMTP_PASS SMTP_FROM

# --- WhatsApp (Twilio) ---
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=whatsapp:+...

# --- Optional ---
WEBHOOK_SECRET=

# --- Other services (optional; not read by core pipeline unless you add code) ---
# DATABASE_URL= RAW_FILES_ROOT= LOG_LEVEL= ENVIRONMENT=
# UPRESS_WP_REST_BASE= UPRESS_WP_APP_USER= UPRESS_WP_APP_PASS=
